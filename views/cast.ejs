<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>M&K Combinatie Radio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;700;900&display=swap" rel="stylesheet">
    <script src="https://www.gstatic.com/cast/sdk/libs/caf_receiver/v3/cast_receiver_framework.js"></script>
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            width: 100vw;
            height: 100vh;
            overflow: hidden;
            font-family: 'Montserrat', sans-serif;
            background: #0d0d1a;
            color: #ffffff;
        }

        /* Blurred background art layer */
        #bg-art {
            position: fixed;
            inset: -5%;
            width: 110%;
            height: 110%;
            background-image: url('/assets/achtergrond.jpg');
            background-size: cover;
            background-position: center;
            filter: blur(40px) brightness(0.25) saturate(1.4);
            z-index: 0;
            transition: background-image 1.5s ease;
        }

        /* Dark gradient overlay for readability */
        #bg-overlay {
            position: fixed;
            inset: 0;
            background: linear-gradient(
                135deg,
                rgba(0, 0, 0, 0.55) 0%,
                rgba(0, 0, 0, 0.3) 50%,
                rgba(0, 0, 0, 0.55) 100%
            );
            z-index: 1;
        }

        /* Main layout */
        #cast-container {
            position: relative;
            z-index: 2;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: clamp(2rem, 5vw, 6rem);
            width: 100%;
            height: 100%;
            padding: clamp(2rem, 6vw, 7rem);
        }

        /* Album art */
        #art-wrapper {
            flex-shrink: 0;
            width: clamp(160px, 36vh, 420px);
            aspect-ratio: 1 / 1;
        }

        #album-art {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: clamp(0.5rem, 2vw, 2rem);
            box-shadow:
                0 0 0 1px rgba(255,255,255,0.08),
                0 clamp(0.5rem, 2vw, 2rem) clamp(2rem, 6vw, 6rem) rgba(0, 0, 0, 0.7);
            transition: opacity 0.6s ease;
        }

        /* Info section */
        #info {
            display: flex;
            flex-direction: column;
            gap: clamp(0.6rem, 1.8vh, 1.8rem);
            min-width: 0;
            max-width: clamp(280px, 48vw, 900px);
        }

        #logo {
            height: clamp(28px, 5.5vh, 70px);
            width: auto;
            object-fit: contain;
            object-position: left center;
            opacity: 0.95;
            margin-bottom: clamp(0.2rem, 0.5vh, 0.8rem);
        }

        #live-badge {
            display: none;
            align-self: flex-start;
            background: #e00;
            color: #fff;
            font-size: clamp(0.6rem, 1.4vw, 1.2rem);
            font-weight: 900;
            letter-spacing: 0.18em;
            text-transform: uppercase;
            padding: 0.25em 0.75em;
            border-radius: 0.35em;
        }

        #now-playing-title {
            font-size: clamp(1.4rem, 4.5vw, 5rem);
            font-weight: 900;
            line-height: 1.05;
            letter-spacing: -0.01em;
            text-shadow: 0 2px 20px rgba(0,0,0,0.5);
            word-break: break-word;
            transition: opacity 0.4s ease;
        }

        #now-playing-artist {
            font-size: clamp(0.9rem, 2.5vw, 2.8rem);
            font-weight: 300;
            opacity: 0.75;
            letter-spacing: 0.02em;
            text-shadow: 0 1px 10px rgba(0,0,0,0.4);
            word-break: break-word;
            transition: opacity 0.4s ease;
        }

        /* Progress indicator (animated when playing) */
        #playing-indicator {
            display: flex;
            align-items: flex-end;
            gap: clamp(3px, 0.4vw, 6px);
            height: clamp(20px, 3vh, 36px);
            margin-top: clamp(0.2rem, 0.5vh, 0.8rem);
        }

        #playing-indicator .bar {
            width: clamp(3px, 0.4vw, 6px);
            background: rgba(255, 255, 255, 0.7);
            border-radius: 2px;
            animation: bounce 1.2s ease-in-out infinite;
        }
        #playing-indicator .bar:nth-child(2) { animation-delay: 0.2s; }
        #playing-indicator .bar:nth-child(3) { animation-delay: 0.4s; }
        #playing-indicator .bar:nth-child(4) { animation-delay: 0.1s; }
        #playing-indicator .bar:nth-child(5) { animation-delay: 0.3s; }

        @keyframes bounce {
            0%, 100% { height: 20%; }
            50%       { height: 100%; }
        }

        /* CAF hidden player (required by Cast framework) */
        cast-media-player {
            display: none;
        }

        /* Portrait / narrow screens (e.g. vertical TV or test on phone) */
        @media (max-aspect-ratio: 4/5) {
            #cast-container {
                flex-direction: column;
                justify-content: center;
                text-align: center;
                gap: clamp(1.5rem, 4vh, 4rem);
            }
            #art-wrapper {
                width: clamp(140px, 55vw, 320px);
            }
            #info {
                align-items: center;
                max-width: 90vw;
            }
            #logo {
                object-position: center;
            }
            #live-badge {
                align-self: center;
            }
        }

        /* Ultra-wide (21:9+) */
        @media (min-aspect-ratio: 21/9) {
            #cast-container {
                gap: clamp(3rem, 6vw, 8rem);
            }
            #art-wrapper {
                width: clamp(180px, 40vh, 380px);
            }
        }
    </style>
</head>
<body>
    <div id="bg-art"></div>
    <div id="bg-overlay"></div>

    <main id="cast-container">
        <div id="art-wrapper">
            <img id="album-art" src="/assets/logo-white.svg" alt="Album Art">
        </div>

        <div id="info">
            <img id="logo" src="/assets/logo-white.svg" alt="M&K Combinatie">
            <span id="live-badge">LIVE</span>
            <div id="now-playing-title">M&amp;K Combinatie</div>
            <div id="now-playing-artist">Live Radio</div>
            <div id="playing-indicator">
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
                <div class="bar"></div>
            </div>
        </div>
    </main>

    <!-- CAF player element (required; kept hidden, audio only) -->
    <cast-media-player></cast-media-player>

    <script src="/cast.js"></script>
</body>
</html>
