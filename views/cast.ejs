<!DOCTYPE html>
<html lang="nl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>M&K Combinatie Radio</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;700;900&display=swap" rel="stylesheet">

    <!-- Cast Application Framework (receiver) -->
    <script src="https://www.gstatic.com/cast/sdk/libs/caf_receiver/v3/cast_receiver_framework.js"></script>

    <style>
        *,
        *::before,
        *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html,
        body {
            width: 100vw;
            height: 100vh;
            overflow: hidden;
            background: #0d0d1a;
        }

        /* Logo shown in the corner while audio is playing.
           --playback-logo-image is the only variable set on the body selector. */
        body {
            --playback-logo-image: url('/assets/logo-white.svg');
        }

        /* Official Web Receiver player element, branded for M&K Combinatie.
           It renders the metadata (title / artist / album art) that cast.js
           puts on the media, and is responsive across every TV / aspect ratio. */
        cast-media-player {
            --background-color: #0d0d1a;
            --background-image: radial-gradient(circle at 30% 30%, #1b1b35 0%, #0d0d1a 70%);

            /* Brand green (#04aa6d ≈ hue 158) drives progress bar + accents */
            --theme-hue: 158;
            --progress-color: #04aa6d;

            --font-family: 'Montserrat', sans-serif;

            /* Logo on launch, splash while idle, watermark during playback */
            --logo-image: url('/assets/logo-white.svg');
            --splash-image: url('/assets/logo-white.svg');
            --splash-size: 32vmin;
            --watermark-image: url('/assets/logo-white.svg');
            --watermark-size: 12vmin;
            --watermark-position: top left;
        }
    </style>
</head>

<body>
    <cast-media-player></cast-media-player>

    <script src="/cast.js"></script>
</body>

</html>